POSTGRES_DB=tupedido
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/tupedido
JWT_SECRET=tupedido-dev-secret
APP_ENV=development
FRONTEND_BASE_URL=https://kepedimos.com
BACKEND_BASE_URL=https://kepedimos.com
SEED_DEMO_DATA=true
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_FULL_NAME=Admin Kepedimos
BOOTSTRAP_ADMIN_EMAIL=admin@kepedimos.com
BOOTSTRAP_ADMIN_PASSWORD=admin1234
BOOTSTRAP_ADMIN_ADDRESS_LABEL=HQ
BOOTSTRAP_ADMIN_ADDRESS_STREET=Av. Corrientes 1000
BOOTSTRAP_ADMIN_ADDRESS_DETAILS=Piso 10, CABA
MERCADOPAGO_SIMULATED=true
# Las credenciales operativas de Mercado Pago se cargan en Admin > Mercado Pago.
# Estas variables son solo bootstrap/fallback tecnico para inicializar la BD en un primer arranque.
# MERCADOPAGO_CLIENT_ID=
# MERCADOPAGO_CLIENT_SECRET=
# MERCADOPAGO_PUBLIC_KEY=
# MERCADOPAGO_REDIRECT_URI=https://kepedimos.com/api/v1/oauth/mercadopago/callback
# MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_API_BASE_URL=https://api.mercadopago.com
MERCADOPAGO_AUTH_BASE_URL=https://auth.mercadopago.com
MERCADOPAGO_TIMEOUT_SECONDS=15
MERCADOPAGO_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300
MERCADOPAGO_CHECKOUT_PRO_FALLBACK_ENABLED=false
MERCADOPAGO_PAYMENT_SESSION_EXPIRE_MINUTES=30
MERCADOPAGO_CARD_PAYMENT_BASE_URL=https://kepedimos.com
SENSITIVE_DATA_KEYS=default:change-this-dedicated-sensitive-key
ACTIVE_KEY_ID=default
ADDRESS_LOOKUP_BASE_URL=https://api.zippopotam.us
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
GEOCODING_USER_AGENT=Kepedimos/0.1 (+https://kepedimos.com)
ADDRESS_LOOKUP_TIMEOUT_SECONDS=10
OPENROUTESERVICE_API_KEY=
OPENROUTESERVICE_BASE_URL=https://api.openrouteservice.org
OPENROUTESERVICE_TIMEOUT_SECONDS=10
DELIVERY_EMBEDDED_WORKER=true
EXPO_PUBLIC_EXPO_PROJECT_ID=
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@kepedimos.com
