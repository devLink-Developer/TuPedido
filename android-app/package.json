{
  "name": "kepedimos-android",
  "version": "1.0.38",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "prebuild:android:release": "node scripts/sync-android-version.cjs",
    "build:android:debug": "cd android && gradlew.bat assembleDebug",
    "build:android:release": "node scripts/build-release-bundle.cjs",
    "build:android:bundle": "node scripts/build-release-bundle.cjs",
    "build:android:standalone": "node scripts/build-release-standalone.cjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.13",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.14.14",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "~19.1.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2",
    "vitest": "^4.1.5"
  },
  "private": true
}
